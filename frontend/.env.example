# Override API URL (optional). Defaults: localhost:8000 in dev, Railway URL in production.
# VITE_API_URL=http://localhost:8000

# Firebase (Project settings → Your apps → Web app)
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# Gemini: set GEMINI_API_KEY on the backend (Railway service variables), not here.
